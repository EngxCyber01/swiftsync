# Awrosoft Hevra IUMS Portal Credentials
# Copy this file to .env and fill in your actual credentials

PORTAL_USERNAME=your-student-email@example.com
PORTAL_PASSWORD=your-password-here

# AI Summarization - Choose ONE (Gemini is FREE!)
# Option 1: Google Gemini (FREE, no credit card required)
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: OpenAI (requires payment)
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Admin SOC - Security Operations Center
# Secret key to access admin portal at /admin-portal?admin_key=YOUR_KEY
SECRET_ADMIN_KEY=your_secret_admin_key_here

# Telegram bot notifications (server-side only; never expose in frontend)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Use one target id. Group id is preferred if you post to a group.
TELEGRAM_GROUP_ID=your_telegram_group_id_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Custom settings
# APP_BASE_URL=https://tempapp-su.awrosoft.com
# SYNC_INTERVAL_SECONDS=3600
# PORT=8000

# Optional: Reverse proxy trust settings (recommended for production behind Cloudflare/Nginx)
# TRUST_PROXY_HEADERS=true
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# Optional: CORS settings for multi-domain deployments
# ALLOWED_ORIGINS=https://swiftsync-013r.onrender.com,https://your-frontend-domain.com
# ALLOWED_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?onrender\.com$|^https://([a-z0-9-]+\.)?up\.railway\.app$
